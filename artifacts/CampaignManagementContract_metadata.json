		"devdoc": {
			"details": "Manages donation campaigns, donor contribution records, milestone proof submissions, and verifier approval or rejection decisions. Donated ETH is not stored in this contract. Every donation is immediately forwarded to MilestoneEscrowContract, where it stays locked until a verifier approves the latest submitted proof. There is intentionally no refund functionality. Donors cannot withdraw.",
			"kind": "dev",
			"methods": {
				"approveProof(uint256)": {
					"details": "Approves the latest submitted proof and releases escrowed funds. Only verifier/admin addresses can approve proof."
				},
				"canApproveProof(uint256)": {
					"details": "Returns whether a campaign currently has submitted proof that can be approved."
				},
				"canSubmitProof(uint256,address)": {
					"details": "Returns whether a charity address can submit proof for a campaign now."
				},
				"createCampaign(string,string,uint256,uint256,address)": {
					"details": "Creates a new donation campaign. The charity wallet is the only address allowed to submit proof later."
				},
				"donate(uint256)": {
					"details": "Accepts a donation and immediately forwards the ETH to escrow. Donations are allowed while the campaign is active or while proof is being reviewed or resubmitted, but never after funds have been released."
				},
				"getCampaign(uint256)": {
					"details": "Returns the full campaign data for Remix testing."
				},
				"getCampaignCount()": {
					"details": "Returns the total number of campaigns created."
				},
				"getDonation(uint256,address)": {
					"details": "Returns how much a donor has contributed to a campaign."
				},
				"getEscrowAddress()": {
					"details": "Returns the configured escrow contract address."
				},
				"getEscrowBalance(uint256)": {
					"details": "Returns the escrow balance for a campaign."
				},
				"getLatestProof(uint256)": {
					"details": "Returns the latest proof URI submitted for a campaign."
				},
				"isVerifier(address)": {
					"details": "Returns whether an address is an approved verifier."
				},
				"rejectProof(uint256,string)": {
					"details": "Rejects the latest submitted proof. Funds remain locked in escrow and the charity can submit new proof later."
				},
				"setEscrowContract(address)": {
					"details": "Updates the escrow contract address if a new escrow contract is deployed."
				},
				"setVerifier(address,bool)": {
					"details": "Adds or removes a verifier address. The admin is a verifier by default."
				},
				"submitProof(uint256,string)": {
					"details": "Allows the campaign charity to submit milestone proof. If proof was rejected before, the charity can submit a new proof URI."
				}
			},
