		"devdoc": {
			"details": "Holds donated ETH for donation campaigns until the campaign management contract tells it to release funds after proof approval. This contract only manages money. It does not store campaign descriptions, proof details, verifier decisions, or donor records.",
			"kind": "dev",
			"methods": {
				"depositFunds(uint256)": {
					"details": "Deposits ETH into escrow for a specific campaign. Only the trusted CampaignManagementContract can call this function."
				},
				"getCampaignContractAddress()": {
					"details": "Returns the trusted CampaignManagementContract address."
				},
				"getEscrowBalance(uint256)": {
					"details": "Returns the ETH currently held for a campaign."
				},
				"isReleased(uint256)": {
					"details": "Returns whether funds for a campaign have already been released."
				},
				"releaseFunds(uint256,address)": {
					"details": "Releases all escrowed ETH for a campaign to the charity address. Uses checks-effects-interactions to prevent re-entrancy issues."
				},
				"setCampaignContract(address)": {
					"details": "Sets the trusted CampaignManagementContract address. Only the escrow admin can set or update this address."
				}
			},
